@model IEnumerable<MyTaskViewModel>
@using Tasks.Domain.Enums
@{
    ViewData["Title"] = "My Tasks";
    Layout = "~/Views/Shared/_Layout.cshtml";

    (string cls, string text) PriorityBadge(PriorityLevel p) => p switch
    {
        PriorityLevel.Low      => ("bg-soft-success text-success", "Low"),
        PriorityLevel.Medium   => ("bg-soft-warning text-warning", "Medium"),
        PriorityLevel.High     => ("bg-soft-danger text-danger", "High"),
        PriorityLevel.Critical => ("bg-danger text-white", "Critical"),
        _ => ("bg-soft-secondary text-secondary", p.ToString())
    };
    (string cls, string text) StatusBadge(WorkTaskStatus s) => s switch
    {
        WorkTaskStatus.Pending    => ("bg-soft-secondary text-secondary", "Pending"),
        WorkTaskStatus.InProgress => ("bg-soft-info text-info", "In Progress"),
        WorkTaskStatus.Completed  => ("bg-soft-success text-success", "Completed"),
        _ => ("bg-soft-secondary text-secondary", s.ToString())
    };
}

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="card"><div class="card-body text-center text-muted py-5">
                <i class="bx bx-task fs-1 d-block mb-2"></i>You have no assigned tasks yet.
            </div></div>
        </div>
    }
    @foreach (var t in Model)
    {
        var pr = PriorityBadge(t.Priority);
        var st = StatusBadge(t.MyStatus);
        <div class="col-xl-4 col-md-6">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-soft-primary text-primary">@t.Code</span>
                        <span class="badge @pr.cls">@pr.text</span>
                    </div>
                    <h5 class="font-size-15 mb-1">@t.Title</h5>
                    <p class="text-muted small mb-2">
                        <i class="bx bx-buildings me-1"></i>@t.CorporationName
                        <span class="ms-2"><i class="bx bx-purchase-tag-alt me-1"></i>@t.Category</span>
                    </p>

                    <div class="mb-2">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Progress</span><span class="fw-medium">@t.ProgressPercent%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-primary" style="width:@(t.ProgressPercent)%"></div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
                        <small class="text-muted"><i class="bx bx-calendar me-1"></i>@t.DueDate.ToString("dd MMM yyyy")</small>
                        <span class="badge @st.cls">@st.text</span>
                    </div>

                    <a asp-action="Work" asp-route-id="@t.Id" class="btn btn-sm btn-primary mt-3 w-100">
                        <i class="bx bx-right-arrow-alt me-1"></i> Open Task
                    </a>
                </div>
            </div>
        </div>
    }
</div>
