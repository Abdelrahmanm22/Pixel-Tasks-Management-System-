@model WorkTaskViewModel
@using Tasks.Domain.Enums
@{
    ViewData["Title"] = "Task Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var assignments = ViewBag.Assignments as List<AssignmentProgressViewModel> ?? new();
    var panel = ViewBag.CommentsPanel as CommentsPanelViewModel ?? new CommentsPanelViewModel { WorkTaskId = Model.Id };

    (string cls, string text) StatusBadge(WorkTaskStatus s) => TaskStatusBadge.Resolve(s);
}

<div class="row">
    <div class="col-xl-7">
        <div class="card">
            <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center py-3">
                <h5 class="card-title mb-0 fw-semibold">
                    <i class="bx bx-detail me-2 text-primary"></i>@Model.Title
                    <span class="badge bg-soft-primary text-primary ms-2">@Model.Code</span>
                </h5>
                <div>
                    <permission required="@Permissions.Tasks.Create">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-success"><i class="bx bx-edit me-1"></i>Edit</a>
                    </permission>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bx bx-arrow-back me-1"></i>Back</a>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6"><small class="text-muted d-block">Type</small><span class="badge bg-soft-dark text-dark">@Model.TaskCategory</span> @Model.TaskTypeName</div>
                    <div class="col-md-6">
                        <small class="text-muted d-block">Status</small>
                        @{ var st = StatusBadge(Model.Status); }
                        <span class="badge @st.cls font-size-12">@st.text</span>
                    </div>
                    <div class="col-md-6"><small class="text-muted d-block">Corporation</small>@Model.CorporationName</div>
                    <div class="col-md-6"><small class="text-muted d-block">Section</small>@(Model.SectionName ?? "All sections")</div>
                    <div class="col-md-6"><small class="text-muted d-block">Request Date</small>@Model.RequestDate.ToString("dd MMM yyyy")</div>
                    <div class="col-md-6"><small class="text-muted d-block">Due Date</small>@Model.DueDate.ToString("dd MMM yyyy")</div>
                    <div class="col-md-6"><small class="text-muted d-block">Created By</small>@Model.CreatedByName</div>
                    @if (Model.TaskCategory == TaskCategory.Counter)
                    {
                        <div class="col-md-6"><small class="text-muted d-block">Target Count</small>@Model.TargetCount</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="col-12"><small class="text-muted d-block">Description</small>@Model.Description</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="col-12"><small class="text-muted d-block">Notes</small>@Model.Notes</div>
                    }
                </div>

                @if (Model.TaskCategory == TaskCategory.Point && Model.Points.Any())
                {
                    <hr />
                    <h6 class="fw-semibold mb-2"><i class="bx bx-list-check me-1"></i>Checklist Points</h6>
                    <ol class="mb-0">
                        @foreach (var p in Model.Points.OrderBy(p => p.Order))
                        {
                            <li>@p.Description</li>
                        }
                    </ol>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-transparent border-bottom py-3">
                <h5 class="card-title mb-0 fw-semibold"><i class="bx bx-group me-2 text-primary"></i>Assignees Progress</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr><th>Employee</th><th width="120">Status</th><th>Progress</th><th width="140" class="text-center">Review</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in assignments)
                            {
                                var ast = StatusBadge(a.Status);
                                <tr id="assignment-row-@a.AssignmentId">
                                    <td class="fw-medium">@a.UserName</td>
                                    <td><span class="badge @ast.cls status-badge">@ast.text</span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:6px;">
                                                <div class="progress-bar bg-primary" style="width:@(a.ProgressPercent)%"></div>
                                            </div>
                                            <small class="text-muted" style="min-width:90px;">
                                                @if (Model.TaskCategory == TaskCategory.Counter)
                                                {
                                                    @($"{a.CompletedCount ?? 0} / {a.TargetCount}")
                                                }
                                                else if (Model.TaskCategory == TaskCategory.Point)
                                                {
                                                    @($"{a.PointsDone} / {a.PointsTotal}")
                                                }
                                                else
                                                {
                                                    @($"{a.ProgressPercent}%")
                                                }
                                            </small>
                                        </div>
                                    </td>
                                    <td class="text-center review-cell">
                                        <permission required="@Permissions.Tasks.Review">
                                            @if (a.Status == WorkTaskStatus.Reviewed)
                                            {
                                                <span class="badge bg-soft-primary text-primary"><i class="bx bx-check-double me-1"></i>Reviewed</span>
                                            }
                                            else if (a.Status == WorkTaskStatus.Completed)
                                            {
                                                <button type="button" class="btn btn-sm btn-primary btn-review"
                                                        data-task-id="@Model.Id" data-assignment-id="@a.AssignmentId" data-name="@a.UserName">
                                                    <i class="bx bx-check-double me-1"></i>Mark Reviewed
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </permission>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        @await Html.PartialAsync("_CommentsChat", panel)
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(document).on('click', '.btn-review', function () {
            const btn          = $(this);
            const taskId       = btn.data('task-id');
            const assignmentId = btn.data('assignment-id');
            const name         = btn.data('name');

            Swal.fire({
                title: 'Mark as Reviewed?',
                html: `Confirm that <strong>"${name}"</strong>'s work has been reviewed.<br><small class="text-muted">This is final and will lock their task from further changes.</small>`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#556ee6',
                cancelButtonColor: '#74788d',
                confirmButtonText: '<i class="bx bx-check-double me-1"></i> Yes, Mark Reviewed',
                cancelButtonText: 'Cancel',
                reverseButtons: true
            }).then((result) => {
                if (!result.isConfirmed) return;

                const data = new FormData();
                data.append('workTaskId', taskId);
                data.append('assignmentId', assignmentId);
                data.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

                fetch('/Task/MarkAssignmentReviewed', { method: 'POST', body: data })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) {
                            const row = $(`#assignment-row-${assignmentId}`);
                            row.find('.status-badge')
                               .removeClass()
                               .addClass('badge bg-soft-primary text-primary status-badge')
                               .text('Reviewed');
                            row.find('.review-cell').html('<span class="badge bg-soft-primary text-primary"><i class="bx bx-check-double me-1"></i>Reviewed</span>');
                            toastr.success(res.message, 'Reviewed', { closeButton: true, progressBar: true, timeOut: 4000 });
                        } else {
                            toastr.error(res.message || 'Failed.', 'Error', { timeOut: 5000 });
                        }
                    })
                    .catch(() => toastr.error('An unexpected error occurred.', 'Error', { timeOut: 5000 }));
            });
        });
    </script>
}
