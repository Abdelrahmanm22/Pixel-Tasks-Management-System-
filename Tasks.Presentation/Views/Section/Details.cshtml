@model Tasks.Presentation.ViewModels.SectionViewModel

@{
    ViewData["Title"] = "Section Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row g-4">

    <!-- Main Info Card -->
    <div class="col-12">
        <div class="card">

            <div class="card-header bg-transparent border-bottom py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="card-title mb-0 fw-semibold">
                        <i class="bx bx-sitemap me-2 text-primary"></i>@Model.Name
                        @if (!string.IsNullOrEmpty(Model.Code))
                        {
                            <span class="badge bg-soft-primary text-primary ms-2 font-size-13">@Model.Code</span>
                        }
                    </h5>
                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary waves-effect">
                            <i class="bx bx-arrow-back me-1"></i> Back
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id"
                           class="btn btn-sm btn-primary waves-effect waves-light">
                            <i class="bx bx-edit me-1"></i> Edit
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">
                <div class="row g-3">

                    <div class="col-md-3">
                        <div class="p-3 border rounded bg-light">
                            <small class="text-muted text-uppercase fw-semibold">Code</small>
                            <div class="mt-1 fw-bold text-primary fs-5">@(Model.Code ?? "—")</div>
                        </div>
                    </div>

                    <div class="col-md-5">
                        <div class="p-3 border rounded bg-light">
                            <small class="text-muted text-uppercase fw-semibold">Name</small>
                            <div class="mt-1 fw-semibold fs-6">@Model.Name</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 border rounded bg-light">
                            <small class="text-muted text-uppercase fw-semibold">Corporation</small>
                            <div class="mt-1 fw-semibold fs-6">@(Model.CorporationName ?? "—")</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted text-uppercase fw-semibold">Email</small>
                                <div class="mt-1">
                                    <a href="mailto:@Model.Email" class="text-primary">@Model.Email</a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted text-uppercase fw-semibold">Phone</small>
                                <div class="mt-1">@Model.Phone</div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Fax))
                    {
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted text-uppercase fw-semibold">Fax</small>
                                <div class="mt-1">@Model.Fax</div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Telex))
                    {
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted text-uppercase fw-semibold">Telex</small>
                                <div class="mt-1">@Model.Telex</div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div class="col-12">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted text-uppercase fw-semibold">Address</small>
                                <div class="mt-1">@Model.Address</div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <div class="col-12">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted text-uppercase fw-semibold">Notes</small>
                                <div class="mt-2 text-secondary">@Model.Notes</div>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>

    <!-- Employees Card -->
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-transparent border-bottom py-3">
                <h5 class="card-title mb-0 fw-semibold">
                    <i class="bx bx-group me-2 text-info"></i>
                    Assigned Employees
                    <span class="badge bg-soft-info text-info ms-2 font-size-13">
                        @Model.AvailableEmployees.Count()
                    </span>
                </h5>
            </div>
            <div class="card-body p-4">
                @if (!Model.AvailableEmployees.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bx bx-user-x fs-1 d-block mb-2"></i>
                        No employees assigned to this section yet.
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var emp in Model.AvailableEmployees)
                        {
                            <div class="col-md-4 col-lg-3">
                                <div class="d-flex align-items-center p-3 border rounded bg-light gap-3">
                                    <div class="avatar-sm flex-shrink-0">
                                        <span class="avatar-title rounded-circle bg-soft-primary text-primary fw-bold">
                                            @emp.FullName.FirstOrDefault()
                                        </span>
                                    </div>
                                    <div class="overflow-hidden">
                                        <div class="fw-semibold text-truncate">@emp.FullName</div>
                                        <small class="text-muted text-truncate d-block">@emp.Email</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts { }
