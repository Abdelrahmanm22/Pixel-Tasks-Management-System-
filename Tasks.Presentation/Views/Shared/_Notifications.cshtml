@*
    _Notifications.cshtml — Reusable TempData notification partial.
    Uses Json.Serialize() to safely escape messages containing quotes or
    special characters inside JavaScript strings.
*@
@if (TempData["Success"] is string successMsg)
{
    <script>
        toastr.options = { closeButton: true, progressBar: true, positionClass: "toast-top-right", timeOut: 4000 };
        toastr.success(@Json.Serialize(successMsg));
    </script>
}
