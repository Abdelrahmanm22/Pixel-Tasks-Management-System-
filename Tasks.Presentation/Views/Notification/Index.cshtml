@model IEnumerable<NotificationViewModel>
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var page = (int)(ViewBag.Page ?? 1);
    var hasNext = (bool)(ViewBag.HasNextPage ?? false);
    var unreadCount = (int)(ViewBag.UnreadCount ?? 0);
}

<div class="card">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <h4 class="card-title mb-0">
                <i class="bx bx-bell me-2 text-primary"></i>Notifications
                @if (unreadCount > 0)
                {
                    <span class="badge bg-danger rounded-pill ms-1">@unreadCount new</span>
                }
            </h4>
            @if (unreadCount > 0)
            {
                <a href="javascript:void(0);" id="mark-all-read-page" class="btn btn-outline-primary btn-sm">
                    <i class="bx bx-check-double me-1"></i> Mark all as read
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bx bx-bell-off font-size-24 d-block mb-2"></i>
                You have no notifications.
            </div>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var n in Model)
                {
                    <a href="@Url.Action("Open", new { id = n.Id })"
                       class="list-group-item list-group-item-action @(n.IsRead ? "" : "bg-light")">
                        <div class="d-flex align-items-center">
                            <div class="avatar-xs me-3">
                                <span class="avatar-title @n.ColorClass rounded-circle font-size-16">
                                    <i class="bx @n.Icon"></i>
                                </span>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-1">
                                    @n.Title
                                    @if (!n.IsRead)
                                    {
                                        <span class="badge bg-soft-danger text-danger ms-1">New</span>
                                    }
                                </h6>
                                <p class="text-muted mb-0 font-size-13">@n.Message</p>
                            </div>
                            <div class="text-muted font-size-12 ms-2 text-nowrap">
                                <i class="mdi mdi-clock-outline"></i> @n.TimeAgo
                            </div>
                        </div>
                    </a>
                }
            </div>

            @if (page > 1 || hasNext)
            {
                <div class="d-flex justify-content-between mt-3">
                    @if (page > 1)
                    {
                        <a asp-action="Index" asp-route-page="@(page - 1)" class="btn btn-outline-secondary btn-sm">
                            <i class="bx bx-chevron-left"></i> Newer
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                    @if (hasNext)
                    {
                        <a asp-action="Index" asp-route-page="@(page + 1)" class="btn btn-outline-secondary btn-sm">
                            Older <i class="bx bx-chevron-right"></i>
                        </a>
                    }
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("mark-all-read-page")?.addEventListener("click", function () {
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";
            fetch("@Url.Action("MarkAllAsRead")", {
                method: "POST",
                headers: { "RequestVerificationToken": token, "X-Requested-With": "XMLHttpRequest" }
            }).then(function () { window.location.reload(); });
        });
    </script>
}
