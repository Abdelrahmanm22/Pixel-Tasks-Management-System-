@model Tasks.Presentation.ViewModels.TaskTypeViewModel

@{
    ViewData["Title"] = "Edit Task Type";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xl-7 col-lg-9">
        <div class="card">
            <div class="card-header bg-transparent border-bottom py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="card-title mb-0 fw-semibold">
                        <i class="bx bx-edit me-2 text-success"></i>Edit Task Type
                    </h5>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary waves-effect">
                        <i class="bx bx-arrow-back me-1"></i> Back to List
                    </a>
                </div>
            </div>

            <div class="card-body p-4">

                <div asp-validation-summary="None" class="text-danger"></div>

                <form asp-action="Edit" asp-controller="TaskType" asp-route-id="@Model.Id"
                      method="post" id="edit-form" novalidate>

                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div class="row g-3">

                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-medium">
                                Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control"
                                   placeholder="e.g. Maintenance Check" />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Category" class="form-label fw-medium">
                                Category <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Category"
                                    asp-items="Html.GetEnumSelectList<Tasks.Domain.Enums.TaskCategory>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="Category" class="text-danger small mt-1 d-block"></span>
                        </div>

                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-action="Details" asp-route-id="@Model.Id"
                           class="btn btn-outline-info waves-effect me-auto">
                            <i class="bx bx-show me-1"></i> View Details
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary waves-effect">
                            <i class="bx bx-x me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-success waves-effect waves-light"
                                id="update-btn">
                            <i class="bx bx-check me-1"></i> Update Task Type
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('edit-form').addEventListener('submit', function () {
            if ($(this).valid()) {
                const btn = document.getElementById('update-btn');
                btn.disabled  = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Updating...';
            }
        });
    </script>
}
