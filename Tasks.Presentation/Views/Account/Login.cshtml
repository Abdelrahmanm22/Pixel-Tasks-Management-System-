@model Tasks.Presentation.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="account-pages my-5 pt-sm-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">
                <div class="card overflow-hidden">

                    <!-- Card header banner -->
                    <div class="bg-primary bg-soft">
                        <div class="row">
                            <div class="col-7">
                                <div class="text-primary p-4">
                                    <h5 class="text-primary">Welcome Back!</h5>
                                    <p>Sign in to continue to Pixel Tasks.</p>
                                </div>
                            </div>
                            <div class="col-5 align-self-end">
                                <img src="~/back/assets/images/profile-img.png" alt="" class="img-fluid">
                            </div>
                        </div>
                    </div>

                    <div class="card-body pt-0">

                        <!-- Logo -->
                        <div class="auth-logo">
                            <a asp-controller="Account" asp-action="Login" class="auth-logo-dark">
                                <div class="avatar-md profile-user-wid mb-4">
                                    <span class="avatar-title rounded-circle bg-light">
                                        <img src="~/back/assets/images/pixel-logo-perfict-mini.png"
                                             alt="Pixel" class="rounded-circle" height="40">
                                    </span>
                                </div>
                            </a>
                            <a asp-controller="Account" asp-action="Login" class="auth-logo-light">
                                <div class="avatar-md profile-user-wid mb-4">
                                    <span class="avatar-title rounded-circle bg-light">
                                        <img src="~/back/assets/images/pixel-logo-perfict-mini.png"
                                             alt="Pixel" class="rounded-circle" height="40">
                                    </span>
                                </div>
                            </a>
                        </div>

                        <div class="p-2">

                            <form class="form-horizontal"
                                  asp-controller="Account"
                                  asp-action="Login"
                                  asp-route-returnUrl="@ViewData["ReturnUrl"]"
                                  method="post"
                                  id="login-form">

                                @Html.AntiForgeryToken()

                                <!-- Global model errors (e.g. wrong credentials) -->
                                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
                                {
                                    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center mb-3" role="alert">
                                        <i class="bx bx-error-circle me-2 fs-5"></i>
                                        <div>
                                            @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                                            {
                                                <span>@error.ErrorMessage</span>
                                            }
                                        </div>
                                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                }

                                <!-- Email or Username -->
                                <div class="mb-3">
                                    <label asp-for="EmailOrUserName" class="form-label"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bx bx-user"></i></span>
                                        <input asp-for="EmailOrUserName"
                                               id="emailOrUserName"
                                               class="form-control"
                                               placeholder="Enter email or username"
                                               autocomplete="username" />
                                    </div>
                                    <span asp-validation-for="EmailOrUserName" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <!-- Password -->
                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label"></label>
                                    <div class="input-group auth-pass-inputgroup">
                                        <span class="input-group-text bg-light"><i class="bx bx-lock-alt"></i></span>
                                        <input asp-for="Password"
                                               id="password-input"
                                               class="form-control"
                                               placeholder="Enter password"
                                               autocomplete="current-password" />
                                        <button class="btn btn-light" type="button" id="password-toggle" tabindex="-1">
                                            <i class="mdi mdi-eye-outline" id="toggle-icon"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <!-- Remember Me -->
                                <div class="form-check mb-3">
                                    <input asp-for="RememberMe" class="form-check-input" id="remember-check" />
                                    <label class="form-check-label" for="remember-check">Remember me</label>
                                </div>

                                <!-- Submit -->
                                <div class="mt-3 d-grid">
                                    <button class="btn btn-primary waves-effect waves-light" type="submit" id="login-btn">
                                        <span id="btn-text"><i class="bx bx-log-in-circle me-1"></i> Log In</span>
                                        <span id="btn-spinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                                    </button>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>

                <!-- Footer note -->
                <div class="mt-5 text-center">
                    <p class="text-muted">
                        Don't have an account?
                        <span class="fw-medium text-primary">Contact your manager to create one.</span>
                    </p>
                    <p class="text-muted">
                        © <script>document.write(new Date().getFullYear())</script>
                        PixelSoft. Crafted with <i class="mdi mdi-heart text-danger"></i> by Pixel Team
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Password show/hide toggle
        document.getElementById('password-toggle').addEventListener('click', function () {
            const input = document.getElementById('password-input');
            const icon  = document.getElementById('toggle-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('mdi-eye-outline', 'mdi-eye-off-outline');
            } else {
                input.type = 'password';
                icon.classList.replace('mdi-eye-off-outline', 'mdi-eye-outline');
            }
        });

        // Show spinner on submit
        document.getElementById('login-form').addEventListener('submit', function () {
            const btn     = document.getElementById('login-btn');
            const text    = document.getElementById('btn-text');
            const spinner = document.getElementById('btn-spinner');
            btn.disabled  = true;
            text.classList.add('d-none');
            spinner.classList.remove('d-none');
        });
    </script>
}