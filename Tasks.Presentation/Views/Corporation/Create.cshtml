@model Tasks.Presentation.ViewModels.CorporationViewModel

@{
    ViewData["Title"] = "Add Corporation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">

        <div class="card">
            <div class="card-header bg-transparent border-bottom py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="card-title mb-0 fw-semibold">
                        <i class="bx bx-plus-circle me-2 text-primary"></i>New Corporation
                    </h5>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary waves-effect">
                        <i class="bx bx-arrow-back me-1"></i> Back to List
                    </a>
                </div>
            </div>

            <div class="card-body p-4">

                <!-- Server-side validation summary (field-less errors only) -->
                <div asp-validation-summary="None" class="text-danger"></div>

                <form asp-action="Create"
                      asp-controller="Corporation"
                      method="post"
                      id="create-form"
                      novalidate>

                    @Html.AntiForgeryToken()

                    <div class="row g-3">

                        <!-- Name -->
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-medium">
                                Corporation Name (EN) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="e.g. Pixel Software" />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <!-- Name Arabic -->
                        <div class="col-md-6">
                            <label asp-for="NameAr" class="form-label fw-medium">
                                Corporation Name (AR)
                            </label>
                            <input asp-for="NameAr"
                                   class="form-control"
                                   dir="rtl"
                                   placeholder="مثال: بيكسل سوفت" />
                            <span asp-validation-for="NameAr" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <!-- Auto-generated Code (read-only info) -->
                        <div class="col-12">
                            <div class="alert alert-info d-flex align-items-center py-2 mb-0" role="alert">
                                <i class="bx bx-info-circle me-2 fs-5"></i>
                                <small>The corporation <strong>Code</strong> will be auto-generated (e.g. <code>PXC-000001</code>) upon saving.</small>
                            </div>
                        </div>

                        <!-- Notes -->
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label fw-medium">Notes</label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Optional notes..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small mt-1 d-block"></span>
                        </div>

                    </div>

                    <!-- Form Actions -->
                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary waves-effect">
                            <i class="bx bx-x me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary waves-effect waves-light" id="save-btn">
                            <i class="bx bx-save me-1"></i> Save Corporation
                        </button>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Only disable button when form is actually valid (prevents getting stuck on validation errors)
        document.getElementById('create-form').addEventListener('submit', function () {
            if ($(this).valid()) {
                const btn = document.getElementById('save-btn');
                btn.disabled  = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving...';
            }
        });
    </script>
}
