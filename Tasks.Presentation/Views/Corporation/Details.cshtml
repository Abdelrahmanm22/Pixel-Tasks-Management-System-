@model Tasks.Presentation.ViewModels.CorporationViewModel
@{
	ViewData["Title"] = "Corporation Details";
	Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="row mb-4">
	<div class="col-12">
		<div class="page-title-box d-flex align-items-center justify-content-between p-0">
			<h4 class="mb-0 fw-bold"></h4>
			<div class="page-title-right">
				<a asp-action="Index" class="btn btn-outline-secondary me-2">
					<i class="fas fa-arrow-left me-1"></i>Back to List
				</a>
				<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
					<i class="fas fa-edit me-1"></i>Edit Corporation
				</a>
			</div>
		</div>
	</div>
</div>

<div class="row g-4">
	<!-- Left Column - Main Info -->
	<div class="col-xl-8">
		<div class="card">
			<div class="card-body p-4">
				<div class="header d-flex justify-content-between align-items-center mb-4">
					<h4 class="card-title mb-0">
						@Model.Name
						@if (!string.IsNullOrEmpty(Model.Code))
						{
							<span class="badge bg-primary">Code: @Model.Code</span>
						}
					</h4>
				</div>

				<div class="row g-3">
					<div class="col-md-4">
						<div class="info-label">Code</div>
						<div class="info-value">@(Model.Code ?? "N/A")</div>
					</div>
					<div class="col-md-4">
						<div class="info-label">Name (English)</div>
						<div class="info-value">@Model.Name</div>
					</div>
					<div class="col-md-4">
						<div class="info-label">Name (Arabic)</div>
						<div class="info-value">@(Model.NameAr ?? "N/A")</div>
					</div>

				</div>
			</div>
		</div>
	</div>

	<!-- Right Column - Summary -->
	<div class="col-xl-4">
		<div class="card">
			<div class="card-body p-4">
				<h5 class="card-title">Notes</h5>
				<div class="row g-3">
					<div class="info-value">
						@(string.IsNullOrWhiteSpace(Model.Notes)
												? "<span class='text-muted'>No notes available</span>"
												: Model.Notes)
					</div>
					<!-- You can add more summary info here later -->
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {

}