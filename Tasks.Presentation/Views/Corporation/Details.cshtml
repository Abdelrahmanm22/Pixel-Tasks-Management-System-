@model Tasks.Presentation.ViewModels.CorporationViewModel

@{
    ViewData["Title"] = "Corporation Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row g-4">

    <!-- Main Info Card -->
    <div class="col-12">
        <div class="card">

            <div class="card-header bg-transparent border-bottom py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="card-title mb-0 fw-semibold">
                        <i class="bx bx-buildings me-2 text-primary"></i>@Model.Name
                        @if (!string.IsNullOrEmpty(Model.Code))
                        {
                            <span class="badge bg-soft-primary text-primary ms-2 font-size-13">@Model.Code</span>
                        }
                    </h5>
                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary waves-effect">
                            <i class="bx bx-arrow-back me-1"></i> Back
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id"
                           class="btn btn-sm btn-primary waves-effect waves-light">
                            <i class="bx bx-edit me-1"></i> Edit
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">
                <div class="row g-4">

                    <!-- Code -->
                    <div class="col-md-4">
                        <div class="p-3 border rounded bg-light">
                            <small class="text-muted text-uppercase fw-semibold letter-spacing-1">Code</small>
                            <div class="mt-1 fw-bold text-primary fs-5">
                                @(Model.Code ?? "—")
                            </div>
                        </div>
                    </div>

                    <!-- Name EN -->
                    <div class="col-md-4">
                        <div class="p-3 border rounded bg-light">
                            <small class="text-muted text-uppercase fw-semibold">Name (English)</small>
                            <div class="mt-1 fw-semibold fs-6">@Model.Name</div>
                        </div>
                    </div>

                    <!-- Name AR -->
                    <div class="col-md-4">
                        <div class="p-3 border rounded bg-light">
                            <small class="text-muted text-uppercase fw-semibold">Name (Arabic)</small>
                            <div class="mt-1 fw-semibold fs-6" dir="rtl">
                                @(string.IsNullOrEmpty(Model.NameAr) ? "—" : Model.NameAr)
                            </div>
                        </div>
                    </div>

                    <!-- Notes -->
                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <div class="col-12">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted text-uppercase fw-semibold">Notes</small>
                                <div class="mt-2 text-secondary">@Model.Notes</div>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts { }