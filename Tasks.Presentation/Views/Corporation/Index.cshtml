@model IEnumerable<CorporationViewModel>

@{
	ViewData["Title"] = "Corporation List";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Table -->
<div class="row">
	<div class="col-12">

		<div class="card">
			<div class="card-body">

				<div class="text-end">
					<a asp-action="Create"
					   class="btn btn-primary mb-3">

						<i class="fas fa-plus me-1"></i>
						Add Corporation

					</a>
				</div>
				<table id="datatable"
					   class="table table-bordered dt-responsive nowrap w-100">

					<thead>
						<tr>

							<th>#</th>
							<th>Code</th>
							<th>Name</th>
							<th>Name Arabic</th>
							<th>Notes</th>
							<th>Actions</th>

						</tr>
					</thead>


					<tbody>
						@{
							var itr = 1;
						}
						@foreach (var corporation in Model)
						{
							<tr>
								<td>
									@(itr++)
								</td>
								<td>
									@corporation.Code
								</td>
								<td>
									@corporation.Name
								</td>
								<td>
									@corporation.NameAr
								</td>
								<td>
									@corporation.Notes
								</td>
								<td>
									<!-- Details -->
									<a asp-action="Details"
									   asp-route-id="@corporation.Id"
									   class="btn btn-sm btn-info"
									   title="View">
										<i class="fas fa-eye"></i>
									</a>
									<!-- Edit -->
									<a asp-action="Edit"
									   asp-route-id="@corporation.Id"
									   class="btn btn-sm btn-success"
									   title="Edit">
										<i class="fas fa-edit"></i>
									</a>
									<!-- Delete -->
									<form asp-action="Delete"
										  asp-route-id="@corporation.Id"
										  method="post"
										  style="display:inline;">
										<button type="submit"
												class="btn btn-sm btn-danger"
												onclick="return confirm('Are you sure?')"
												title="Delete">

											<i class="fas fa-trash"></i>
										</button>
									</form>
								</td>
							</tr>
						}

					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>




@section Scripts {
	<!-- DataTables -->
	<script src="~/back/assets/libs/datatables.net/js/jquery.dataTables.min.js"></script>
	<script src="~/back/assets/libs/datatables.net-bs4/js/dataTables.bootstrap4.min.js"></script>
	<script src="~/back/assets/libs/datatables.net-responsive/js/dataTables.responsive.min.js"></script>
	<script src="~/back/assets/libs/datatables.net-responsive-bs4/js/responsive.bootstrap4.min.js"></script>
	<script src="~/back/assets/js/pages/datatables.init.js"></script>
}